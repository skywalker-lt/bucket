# Master secret for file encryption key derivation (change this!)
MASTER_SECRET=change-me-to-a-long-random-string

# PBKDF2 settings
PBKDF2_SALT=change-me-to-a-random-salt
PBKDF2_ITERATIONS=600000

# WebAuthn settings
RP_ID=localhost
RP_NAME=SecureVault
RP_ORIGIN=https://localhost

# Twilio Verify settings (for SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
OWNER_PHONE_NUMBER=

# Session settings
SESSION_SECRET=change-me-session-secret

# Storage paths
STORAGE_PATH=./storage
DATABASE_PATH=./data/vault.db

# Upload limit in bytes (default 100MB)
MAX_UPLOAD_SIZE=104857600
